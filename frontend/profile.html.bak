<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Profile Setup — SmartApply</title>
  <link rel="stylesheet" href="css/main.css" />
  <style>
    .profile-layout { display: grid; grid-template-columns: 220px 1fr; gap: 32px; align-items: start; }
    .profile-nav { position: sticky; top: 88px; }
    .profile-nav-item {
      display: flex; align-items: center; gap: 10px;
      padding: 10px 14px; border-radius: var(--radius-sm);
      font-size: 14px; color: var(--text-2); cursor: pointer;
      transition: var(--transition); margin-bottom: 2px;
    }
    .profile-nav-item:hover { background: var(--surface); color: var(--text); }
    .profile-nav-item.active { background: rgba(79,124,255,0.1); color: var(--primary); font-weight: 500; }
    .profile-nav-item .check { margin-left: auto; color: var(--accent); font-size: 14px; display: none; }
    .profile-nav-item.done .check { display: block; }
    .section-panel { display: none; }
    .section-panel.active { display: block; animation: fadeIn 0.3s ease; }
    .tag-input-wrap {
      min-height: 46px;
      background: var(--bg-2);
      border: 1.5px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 8px 10px;
      display: flex; flex-wrap: wrap; gap: 6px; align-items: center;
      cursor: text;
    }
    .tag-input-wrap:focus-within { border-color: var(--primary); }
    @media (max-width: 700px) { .profile-layout { grid-template-columns: 1fr; } .profile-nav { display: none; } }
  </style>
</head>
<body>
  <div class="bg-grid"></div>
  <div id="toast-container"></div>

  <nav class="navbar">
    <div class="container">
      <a href="index.html" class="nav-logo"><div class="logo-dot"></div>Smart<span>Apply</span></a>
      <div class="nav-links" id="nav-actions"></div>
    </div>
  </nav>

  <div class="page-wrapper">
    <div class="container" style="padding-top:40px;padding-bottom:80px">
      <div style="margin-bottom:36px;display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px">
        <div>
          <h2>Profile Setup</h2>
          <p class="text-muted" style="margin-top:6px">Fill in your details so the bot can apply accurately on your behalf</p>
        </div>
        <a href="resume.html" class="btn btn-ghost">← Resume Upload</a>
      </div>

      <div class="profile-layout">
        <!-- Sidebar nav -->
        <nav class="profile-nav">
          <div class="profile-nav-item active" data-section="personal" onclick="switchSection(this)">
            <span>👤</span> Personal <span class="check">✓</span>
          </div>
          <div class="profile-nav-item" data-section="professional" onclick="switchSection(this)">
            <span>💼</span> Professional <span class="check">✓</span>
          </div>
          <div class="profile-nav-item" data-section="preferences" onclick="switchSection(this)">
            <span>🎯</span> Job Preferences <span class="check">✓</span>
          </div>
          <div class="profile-nav-item" data-section="platforms" onclick="switchSection(this)">
            <span>🔐</span> Platform Logins <span class="check">✓</span>
          </div>
        </nav>

        <!-- Content -->
        <div>
          <!-- Personal -->
          <div class="section-panel active" id="section-personal">
            <div class="card">
              <h4 style="margin-bottom:24px">Personal Details</h4>
              <div class="grid-2">
                <div class="form-group"><label>First Name</label><input type="text" id="first_name" placeholder="Rahul" /></div>
                <div class="form-group"><label>Last Name</label><input type="text" id="last_name" placeholder="Sharma" /></div>
                <div class="form-group"><label>Middle Name</label><input type="text" id="middle_name" placeholder="(Optional)" /></div>
                <div class="form-group"><label>Phone Number</label><input type="tel" id="phone_number" placeholder="9876543210" maxlength="10" /></div>
                <div class="form-group"><label>Current City</label><input type="text" id="current_city" placeholder="Hyderabad" /></div>
                <div class="form-group"><label>State</label><input type="text" id="state" placeholder="Telangana" /></div>
                <div class="form-group"><label>Pincode</label><input type="text" id="zipcode" placeholder="500001" /></div>
                <div class="form-group"><label>Country</label><input type="text" id="country" value="India" /></div>
                <div class="form-group" style="grid-column:span 2"><label>Street Address</label><input type="text" id="street" placeholder="123, Main Street" /></div>
              </div>
              <div style="margin-top:24px">
                <h4 style="margin-bottom:16px;font-size:0.95rem;color:var(--text-2)">Equal Opportunity (Optional)</h4>
                <div class="grid-2">
                  <div class="form-group">
                    <label>Gender</label>
                    <select id="gender">
                      <option value="">Prefer not to say</option>
                      <option value="Male">Male</option>
                      <option value="Female">Female</option>
                      <option value="Other">Other</option>
                      <option value="Decline">Decline</option>
                    </select>
                  </div>
                  <div class="form-group">
                    <label>Disability Status</label>
                    <select id="disability_status">
                      <option value="Decline">Decline</option>
                      <option value="Yes">Yes</option>
                      <option value="No">No</option>
                    </select>
                  </div>
                </div>
              </div>
              <div style="margin-top:20px;text-align:right">
                <button class="btn btn-primary" onclick="saveAndNext('personal','professional')">Next: Professional →</button>
              </div>
            </div>
          </div>

          <!-- Professional -->
          <div class="section-panel" id="section-professional">
            <div class="card">
              <h4 style="margin-bottom:24px">Professional Details</h4>
              <div style="display:flex;flex-direction:column;gap:16px">
                <div class="form-group"><label>LinkedIn Profile URL</label><input type="url" id="linkedin_profile" placeholder="https://linkedin.com/in/yourname" /></div>
                <div class="form-group"><label>Portfolio Website</label><input type="url" id="website" placeholder="https://yourportfolio.com" /></div>
                <div class="form-group"><label>Years of Experience</label>
                  <select id="years_of_experience">
                    <option value="0">0 — Fresher / Intern</option>
                    <option value="1">1 year</option>
                    <option value="2">2 years</option>
                    <option value="3">3 years</option>
                    <option value="4">4 years</option>
                    <option value="5">5 years</option>
                    <option value="6">6+ years</option>
                  </select>
                </div>
                <div class="grid-2">
                  <div class="form-group"><label>Desired Salary (₹ per annum)</label><input type="number" id="desired_salary" placeholder="800000" /></div>
                  <div class="form-group"><label>Notice Period (days)</label><input type="number" id="notice_period" placeholder="0" /></div>
                </div>
                <div class="form-group"><label>LinkedIn Headline <span class="text-muted">(120 chars)</span></label><input type="text" id="linkedin_headline" placeholder="MBA Finance | Financial Analyst | Excel | SQL" maxlength="120" /></div>
                <div class="form-group"><label>LinkedIn Summary / About</label><textarea id="linkedin_summary" rows="4" placeholder="Write a short professional bio…"></textarea></div>
                <div class="form-group">
                  <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:7px">
                    <label style="margin-bottom:0">Cover Letter Template</label>
                    <button type="button" class="btn btn-ghost btn-sm" id="ai-cover-btn" onclick="generateAICoverLetter()" style="font-size:12px">
                      <span class="spinner"></span><span class="btn-text">✨ Generate with AI</span>
                    </button>
                  </div>
                  <textarea id="cover_letter" rows="6" placeholder="Dear Hiring Manager,&#10;&#10;I am…"></textarea>
                </div>
                <div class="form-group"><label>Skills Summary</label><textarea id="skills_summary" rows="3" placeholder="Python, SQL, Excel, Power BI, Data Analysis…"></textarea></div>
              </div>
              <div style="margin-top:20px;display:flex;gap:12px;justify-content:space-between">
                <button class="btn btn-ghost" onclick="switchSectionById('personal')">← Back</button>
                <button class="btn btn-primary" onclick="saveAndNext('professional','preferences')">Next: Job Preferences →</button>
              </div>
            </div>
          </div>

          <!-- Job Preferences -->
          <div class="section-panel" id="section-preferences">
            <div class="card">
              <h4 style="margin-bottom:24px">Job Preferences</h4>
              <div style="display:flex;flex-direction:column;gap:18px">
                <div class="form-group">
                  <label>Search Terms (Job Titles)</label>
                  <div class="tag-input-wrap" id="search-terms-tags"></div>
                  <input type="hidden" id="search_terms" />
                  <span class="text-sm text-muted" style="margin-top:4px">Type a job title and press Enter. E.g. "Business Analyst"</span>
                </div>
                <div class="form-group"><label>Preferred Location</label><input type="text" id="search_location" placeholder="India" value="India" /></div>
                <div class="form-group">
                  <label>Experience Level</label>
                  <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:4px" id="exp-level-group">
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="exp_level" value="Internship" style="margin-right:6px">Internship</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="exp_level" value="Entry level" checked style="margin-right:6px">Entry level</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="exp_level" value="Associate" style="margin-right:6px">Associate</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="exp_level" value="Mid-Senior level" style="margin-right:6px">Mid-Senior</label>
                  </div>
                </div>
                <div class="form-group">
                  <label>Job Type</label>
                  <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:4px">
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="job_type" value="Full-time" checked style="margin-right:6px">Full-time</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="job_type" value="Internship" style="margin-right:6px">Internship</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="job_type" value="Part-time" style="margin-right:6px">Part-time</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="job_type" value="Contract" style="margin-right:6px">Contract</label>
                  </div>
                </div>
                <div class="form-group">
                  <label>Work Mode</label>
                  <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:4px">
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="on_site" value="On-site" checked style="margin-right:6px">On-site</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="on_site" value="Hybrid" checked style="margin-right:6px">Hybrid</label>
                    <label class="badge badge-neutral" style="cursor:pointer"><input type="checkbox" name="on_site" value="Remote" checked style="margin-right:6px">Remote</label>
                  </div>
                </div>
                <div class="form-group"><label>Date Posted Filter</label>
                  <select id="date_posted">
                    <option value="Past week">Past week</option>
                    <option value="Past month" selected>Past month</option>
                    <option value="Past 24 hours">Past 24 hours</option>
                    <option value="Any time">Any time</option>
                  </select>
                </div>
                <div class="toggle-row">
                  <div>
                    <div style="font-size:14px;font-weight:500">Easy Apply Only</div>
                    <div class="text-sm text-muted">Only apply to one-click Easy Apply jobs</div>
                  </div>
                  <label class="toggle"><input type="checkbox" id="easy_apply_only" checked /><span class="toggle-slider"></span></label>
                </div>
                <div class="form-group">
                  <label>Keywords to Skip (Bad Words)</label>
                  <div class="tag-input-wrap" id="bad-words-tags"></div>
                  <input type="hidden" id="bad_words" />
                  <span class="text-sm text-muted" style="margin-top:4px">Jobs containing these words will be skipped</span>
                </div>
              </div>
              <div style="margin-top:20px;display:flex;gap:12px;justify-content:space-between">
                <button class="btn btn-ghost" onclick="switchSectionById('professional')">← Back</button>
                <button class="btn btn-primary" onclick="saveAndNext('preferences','platforms')">Next: Platform Logins →</button>
              </div>
            </div>
          </div>

          <!-- Platform Logins -->
          <div class="section-panel" id="section-platforms">
            <div class="card">
              <div class="alert alert-info" style="margin-bottom:24px">
                <span>🔒</span>
                <span>Credentials are stored encrypted and only used by the automation bot. Your registration email is separate from these.</span>
              </div>
              <h4 style="margin-bottom:20px">Platform Login Credentials</h4>

              <div style="display:flex;flex-direction:column;gap:24px">
                <div>
                  <div style="font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:8px">💼 LinkedIn</div>
                  <div class="grid-2">
                    <div class="form-group"><label>LinkedIn Email</label><input type="email" id="linkedin_email" placeholder="your@email.com" /></div>
                    <div class="form-group"><label>LinkedIn Password</label><input type="password" id="linkedin_password" placeholder="••••••••" /></div>
                  </div>
                </div>
                <hr style="border-color:var(--border)">
                <div>
                  <div style="font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:8px">🔍 Indeed</div>
                  <div class="grid-2">
                    <div class="form-group"><label>Indeed Email</label><input type="email" id="indeed_email" placeholder="your@email.com" /></div>
                    <div class="form-group"><label>Indeed Password</label><input type="password" id="indeed_password" placeholder="••••••••" /></div>
                  </div>
                </div>
                <hr style="border-color:var(--border)">
                <div>
                  <div style="font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:8px">🎓 Internshala</div>
                  <div class="grid-2">
                    <div class="form-group"><label>Internshala Email</label><input type="email" id="internshala_email" placeholder="your@email.com" /></div>
                    <div class="form-group"><label>Internshala Password</label><input type="password" id="internshala_password" placeholder="••••••••" /></div>
                  </div>
                </div>
                <hr style="border-color:var(--border)">
                <div>
                  <div style="font-weight:600;margin-bottom:12px;display:flex;align-items:center;gap:8px">📋 Naukri</div>
                  <div class="grid-2">
                    <div class="form-group"><label>Naukri Email</label><input type="email" id="naukri_email" placeholder="your@email.com" /></div>
                    <div class="form-group"><label>Naukri Password</label><input type="password" id="naukri_password" placeholder="••••••••" /></div>
                  </div>
                </div>
              </div>

              <div style="margin-top:28px;display:flex;gap:12px;justify-content:space-between">
                <button class="btn btn-ghost" onclick="switchSectionById('preferences')">← Back</button>
                <button class="btn btn-accent btn-lg" id="finish-btn" onclick="saveAll()">
                  <span class="spinner"></span>
                  <span class="btn-text">Save & Go to Dashboard →</span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="js/app.js"></script>
  <script>
    if (!auth.requireAuth()) throw new Error();

    // ── Navigation ────────────────────────────────────────────────────────
    function switchSection(item) {
      document.querySelectorAll('.profile-nav-item').forEach(n => n.classList.remove('active'));
      document.querySelectorAll('.section-panel').forEach(p => p.classList.remove('active'));
      item.classList.add('active');
      document.getElementById('section-' + item.dataset.section).classList.add('active');
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
    function switchSectionById(id) {
      const item = document.querySelector(`[data-section="${id}"]`);
      if (item) switchSection(item);
    }
    function saveAndNext(currentSection, nextSection) {
      saveSectionLocally(currentSection);
      document.querySelector(`[data-section="${currentSection}"]`).classList.add('done');
      switchSectionById(nextSection);
    }

    // ── Tag inputs ────────────────────────────────────────────────────────
    initTagInput('search-terms-tags', 'search_terms', []);
    initTagInput('bad-words-tags', 'bad_words', ['US Citizen', '10+ years']);

    // ── Load existing profile, then overlay parsed resume data ────────────
    // NOTE: parsed data is applied AFTER the API load so it always wins.
    const parsed = (() => { try { return JSON.parse(sessionStorage.getItem('parsed_profile')); } catch { return null; } })();

    api.get('/profile/me').then(data => {
      const p = data.profile || {};
      const jp = data.job_preferences || {};
      const pa = data.platform_accounts || {};
      const fillIf = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };

      Object.entries(p).forEach(([k, v]) => fillIf(k, v));

      // Job prefs
      fillIf('search_location', jp.search_location);
      fillIf('date_posted', jp.date_posted);
      if (jp.easy_apply_only !== undefined) document.getElementById('easy_apply_only').checked = jp.easy_apply_only;
      if (jp.search_terms?.length) initTagInput('search-terms-tags', 'search_terms', jp.search_terms);
      if (jp.bad_words?.length) initTagInput('bad-words-tags', 'bad_words', jp.bad_words);

      // Checkboxes
      ['exp_level', 'job_type', 'on_site'].forEach(name => {
        const field = { exp_level: 'experience_level', job_type: 'job_type', on_site: 'on_site' }[name];
        const values = jp[field] || [];
        if (values.length) {
          document.querySelectorAll(`[name="${name}"]`).forEach(cb => {
            cb.checked = values.includes(cb.value);
          });
        }
      });

      // Platform accounts
      Object.entries(pa).forEach(([k, v]) => { if (!k.includes('password')) fillIf(k, v); });

      // ── Overlay parsed resume data on top (runs after server data so it wins) ──
      if (parsed) {
        fillIf('first_name', parsed.first_name);
        fillIf('last_name', parsed.last_name);
        fillIf('middle_name', parsed.middle_name);
        fillIf('phone_number', parsed.phone_number);
        fillIf('current_city', parsed.current_city);
        fillIf('state', parsed.state);
        fillIf('years_of_experience', parsed.years_of_experience);
        fillIf('linkedin_profile', parsed.linkedin_profile);
        fillIf('website', parsed.website);
        fillIf('linkedin_headline', parsed.linkedin_headline);
        fillIf('linkedin_summary', parsed.linkedin_summary);
        fillIf('cover_letter', parsed.cover_letter);
        fillIf('skills_summary', parsed.skills_summary);
        if (parsed.search_terms?.length) {
          initTagInput('search-terms-tags', 'search_terms', parsed.search_terms);
        }
        showToast('Profile pre-filled from resume!', 'success');
        sessionStorage.removeItem('parsed_profile');
      }
    }).catch(() => {
      // If API fails but we have parsed data, still fill from resume
      if (parsed) {
        const fillIf = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
        fillIf('first_name', parsed.first_name);
        fillIf('last_name', parsed.last_name);
        fillIf('middle_name', parsed.middle_name);
        fillIf('phone_number', parsed.phone_number);
        fillIf('current_city', parsed.current_city);
        fillIf('state', parsed.state);
        fillIf('years_of_experience', parsed.years_of_experience);
        fillIf('linkedin_profile', parsed.linkedin_profile);
        fillIf('website', parsed.website);
        fillIf('linkedin_headline', parsed.linkedin_headline);
        fillIf('linkedin_summary', parsed.linkedin_summary);
        fillIf('cover_letter', parsed.cover_letter);
        fillIf('skills_summary', parsed.skills_summary);
        if (parsed.search_terms?.length) {
          initTagInput('search-terms-tags', 'search_terms', parsed.search_terms);
        }
        showToast('Profile pre-filled from resume!', 'success');
        sessionStorage.removeItem('parsed_profile');
      }
    });

    function saveSectionLocally(section) { /* handled during saveAll */ }

    // ── Save all ──────────────────────────────────────────────────────────
    async function saveAll() {
      const btn = document.getElementById('finish-btn');
      setLoading(btn, true);

      // Profile data
      const profileData = {
        first_name: document.getElementById('first_name').value.trim(),
        last_name:  document.getElementById('last_name').value.trim(),
        middle_name: document.getElementById('middle_name').value.trim(),
        phone_number: document.getElementById('phone_number').value.trim(),
        current_city: document.getElementById('current_city').value.trim(),
        state: document.getElementById('state').value.trim(),
        zipcode: document.getElementById('zipcode').value.trim(),
        country: document.getElementById('country').value.trim(),
        street: document.getElementById('street').value.trim(),
        gender: document.getElementById('gender').value,
        disability_status: document.getElementById('disability_status').value,
        linkedin_profile: document.getElementById('linkedin_profile').value.trim(),
        website: document.getElementById('website').value.trim(),
        years_of_experience: document.getElementById('years_of_experience').value,
        desired_salary: parseInt(document.getElementById('desired_salary').value) || null,
        notice_period: parseInt(document.getElementById('notice_period').value) || 0,
        linkedin_headline: document.getElementById('linkedin_headline').value.trim(),
        linkedin_summary: document.getElementById('linkedin_summary').value.trim(),
        cover_letter: document.getElementById('cover_letter').value.trim(),
        skills_summary: document.getElementById('skills_summary').value.trim(),
      };

      // Job preferences
      const getChecked = name => [...document.querySelectorAll(`[name="${name}"]:checked`)].map(c => c.value);
      const jobPrefs = {
        search_terms: JSON.parse(document.getElementById('search_terms').value || '[]'),
        search_location: document.getElementById('search_location').value.trim(),
        experience_level: getChecked('exp_level'),
        job_type: getChecked('job_type'),
        on_site: getChecked('on_site'),
        date_posted: document.getElementById('date_posted').value,
        easy_apply_only: document.getElementById('easy_apply_only').checked,
        bad_words: JSON.parse(document.getElementById('bad_words').value || '[]'),
      };

      // Platform accounts
      const platforms = {
        linkedin_email: document.getElementById('linkedin_email').value.trim(),
        linkedin_password: document.getElementById('linkedin_password').value,
        indeed_email: document.getElementById('indeed_email').value.trim(),
        indeed_password: document.getElementById('indeed_password').value,
        internshala_email: document.getElementById('internshala_email').value.trim(),
        internshala_password: document.getElementById('internshala_password').value,
        naukri_email: document.getElementById('naukri_email').value.trim(),
        naukri_password: document.getElementById('naukri_password').value,
      };

      try {
        await api.put('/profile/update', profileData);
        await api.put('/profile/job-preferences', jobPrefs);
        await api.put('/profile/platform-accounts', platforms);
        showToast('Profile saved!', 'success');
        setTimeout(() => window.location.href = 'dashboard.html', 900);
      } catch (err) {
        showToast(err.detail || 'Could not save profile', 'error');
        setLoading(btn, false);
      }
    }

    // ── AI Cover Letter ──────────────────────────────────────────────────
    async function generateAICoverLetter() {
      const btn = document.getElementById('ai-cover-btn');
      if (!btn) return;
      setLoading(btn, true);
      const parts = [
        document.getElementById('first_name').value + ' ' + document.getElementById('last_name').value,
        document.getElementById('linkedin_headline').value,
        document.getElementById('skills_summary').value,
        (document.getElementById('years_of_experience').value || '0') + ' years experience',
        document.getElementById('linkedin_summary').value,
      ].filter(Boolean);
      const userInfo = parts.join('
');
      const terms = (() => { try { return JSON.parse(document.getElementById('search_terms').value || '[]'); } catch { return []; } })();
      const jobTitle = terms[0] || 'the open position';
      try {
        const data = await api.post('/ai/cover-letter', { user_info: userInfo, job_title: jobTitle, company: 'your organisation' });
        document.getElementById('cover_letter').value = data.cover_letter;
        showToast('Cover letter generated with AI!', 'success');
      } catch (err) {
        showToast(err.detail || 'AI unavailable — check your OpenRouter keys', 'error');
      } finally {
        setLoading(btn, false);
      }
    }
  </script>
</body>
</html>
